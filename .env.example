# Environment Variables for PawCare (EXAMPLE)
# Copy this to .env and fill in your actual values.
# DO NOT COMMIT YOUR .ENV FILE TO GIT.

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Session Secret
SESSION_SECRET=a-secure-random-secret-key

# MySQL Database Configuration
USE_JSON=true         # Set to true to use pawcare-data.json for storage
USE_MYSQL=false        # Set to true to use MySQL instead of SQLite
# DATABASE_URL=        # (Optional) Postgres or MySQL connection string
ADMIN_EMAIL=admin@pawcare.com
ADMIN_PASSWORD=change-me-immediately

# Server Configuration
PORT=3000
NODE_ENV=development
